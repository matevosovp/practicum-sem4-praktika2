# Local development defaults
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=.
RECSYS_AIRFLOW_CONN_ID=recsys_postgres
AIRFLOW_CONN_RECSYS_POSTGRES=postgresql://airflow:airflow@postgres:5432/airflow?sslmode=disable

# Application and artifacts
MODEL_PATH=models/recommender.joblib
MLFLOW_TRACKING_URI=file:./artifacts/mlruns

# Optional S3-compatible MLflow storage
# MLFLOW_S3_ENDPOINT_URL=https://storage.example.com
# S3_BUCKET_NAME=replace-me
# AWS_ACCESS_KEY_ID=replace-me
# AWS_SECRET_ACCESS_KEY=replace-me
